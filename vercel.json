{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "gh-pages": false
    }
  },
  "rewrites": [
    { "source": "/CookingMAMA", "destination": "/" },
    { "source": "/CookingMAMA/", "destination": "/" },
    { "source": "/CookingMAMA/:path*", "destination": "/:path*" }
  ]
}
