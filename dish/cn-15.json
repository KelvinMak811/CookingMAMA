{
  "id": "cn-15",
  "name": "薯仔牛柳粒",
  "cuisine": "chinese",
  "baseServings": 2,
  "description": "茶餐廳經典黑椒薯仔牛柳粒，外脆內嫩，一個易潔鑊就煮到。",
  "difficulty": 2,
  "prepTime": 35,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/a/a3/Irish_stew.jpg/960px-Irish_stew.jpg",
  "ingredients": [
    {
      "id": "cn15-1",
      "name": "牛柳",
      "amount": "300g"
    },
    {
      "id": "cn15-2",
      "name": "薯仔",
      "amount": "2個"
    },
    {
      "id": "cn15-3",
      "name": "洋蔥",
      "amount": "半個"
    },
    {
      "id": "cn15-4",
      "name": "黑椒汁",
      "amount": "3湯匙"
    },
    {
      "id": "cn15-5",
      "name": "生抽",
      "amount": "1湯匙"
    },
    {
      "id": "cn15-6",
      "name": "生粉",
      "amount": "1湯匙"
    }
  ],
  "steps": [
    "牛柳切粒（約2厘米），生抽、油、生粉醃20分鐘。",
    "薯仔去皮切粒，沖水洗去澱粉，抹乾備用。",
    "洋蔥切塊；黑椒汁可加1湯匙水調開。",
    "易潔鑊中火下油，先煎薯仔粒約5–6分鐘至表面金黃熟透，盛起。",
    "大火下牛柳粒快炒至七成熟變色，盛起。",
    "鑊下少許油炒洋蔥至透明，倒回薯仔同牛柳，淋黑椒汁大火兜匀收汁。",
    "汁濃稠裹勻即可起鑊，配白飯或意粉都得。"
  ]
}
