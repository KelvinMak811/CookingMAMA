{
  "id": "cn-20",
  "name": "黑椒豬頸肉意粉",
  "cuisine": "chinese",
  "baseServings": 2,
  "description": "港式茶餐廳風味，豬頸肉配黑椒意粉，一鑊過超方便。",
  "difficulty": 2,
  "prepTime": 25,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/8/89/Pasta_with_beef.jpg/960px-Pasta_with_beef.jpg",
  "ingredients": [
    {
      "id": "cn20-1",
      "name": "豬頸肉",
      "amount": "300g"
    },
    {
      "id": "cn20-2",
      "name": "意粉",
      "amount": "200g"
    },
    {
      "id": "cn20-3",
      "name": "洋蔥",
      "amount": "半個"
    },
    {
      "id": "cn20-4",
      "name": "黑椒汁",
      "amount": "3湯匙"
    },
    {
      "id": "cn20-5",
      "name": "蒜蓉",
      "amount": "2瓣"
    }
  ],
  "steps": [
    "意粉按包裝時間煮軟，瀝乾留半杯麵水。",
    "豬頸肉切條，少許鹽同油醃10分鐘；洋蔥切絲。",
    "易潔鑊大火下油，炒豬頸肉至金黃熟透，盛起。",
    "爆香蒜蓉同洋蔥，倒黑椒汁同少許麵水煮滾。",
    "下意粉同豬頸肉大火兜匀，汁收濃即可。",
    "即起鑊，可加少許芝士粉。"
  ]
}
