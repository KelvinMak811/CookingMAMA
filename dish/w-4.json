{
  "id": "w-4",
  "name": "蕃茄肉醬意粉",
  "cuisine": "western",
  "baseServings": 3,
  "description": "經典肉醬意粉，一次煮幾多餐好啱，易潔鑊燜煮。",
  "difficulty": 2,
  "prepTime": 35,
  "imageUrl": "https://www.themealdb.com/images/media/meals/sutysw1468247559.jpg",
  "ingredients": [
    {
      "id": "w4-1",
      "name": "意粉",
      "amount": "300g"
    },
    {
      "id": "w4-2",
      "name": "免治牛肉",
      "amount": "300g"
    },
    {
      "id": "w4-3",
      "name": "番茄罐頭",
      "amount": "1罐"
    },
    {
      "id": "w4-4",
      "name": "洋蔥",
      "amount": "1個"
    },
    {
      "id": "w4-5",
      "name": "蒜蓉",
      "amount": "3瓣"
    }
  ],
  "steps": [
    "洋蔥切細丁（約半厘米見方）；蒜切細末；意粉按包裝時間煮至彈牙，瀝乾備用。",
    "易潔鑊中火加少許油，下免治牛肉炒散，大火快炒約3至4分鐘至變色、無粉紅肉粒。",
    "加入洋蔥丁同蒜蓉，轉中火炒2至3分鐘，炒至洋蔥半透明、出香。",
    "倒入番茄罐頭連汁，拌勻後加少許鹽同黑胡椒，蓋蓋轉中小火燜煮15至18分鐘。",
    "期間間中攪拌，見醬汁收濃、油邊微微泛紅即代表煮夠味。",
    "拌入煮好的意粉，大火兜炒1至2分鐘，讓每條麵裹上肉醬即可起鑊。"
  ]
}
