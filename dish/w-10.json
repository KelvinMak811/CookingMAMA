{
  "id": "w-10",
  "name": "蔬菜雜燴一鑊煮",
  "cuisine": "western",
  "baseServings": 3,
  "description": "健康低脂，易潔鑊燜煮蔬菜配雞肉，適合備餐。",
  "difficulty": 1,
  "prepTime": 30,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/7/78/Chicken_stew.jpg/960px-Chicken_stew.jpg",
  "ingredients": [
    {
      "id": "w10-1",
      "name": "雞胸肉",
      "amount": "300g"
    },
    {
      "id": "w10-2",
      "name": "西蘭花",
      "amount": "200g"
    },
    {
      "id": "w10-3",
      "name": "甘筍",
      "amount": "1條"
    },
    {
      "id": "w10-4",
      "name": "薯仔",
      "amount": "2個"
    },
    {
      "id": "w10-5",
      "name": "雞湯",
      "amount": "300ml"
    }
  ],
  "steps": [
    "雞胸肉切約3厘米塊；薯仔、甘筍去皮切滾刀塊（每塊約3厘米）；西蘭花切小朵浸鹽水洗淨。",
    "易潔鑊中火加少許油，下雞肉塊煎至表面金黃，約每面2至3分鐘。",
    "加入薯仔同甘筍塊，翻炒1分鐘讓表面略煎香。",
    "倒入雞湯，蓋蓋轉中小火燜煮15分鐘，至薯仔筷子可插入。",
    "加入西蘭花，再蓋蓋燜5分鐘，西蘭花變翠綠、仍帶爽脆。",
    "試味加鹽同黑胡椒，汁收至略濃即可起鑊。"
  ]
}
