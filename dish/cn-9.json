{
  "id": "cn-9",
  "name": "魚香茄子",
  "cuisine": "chinese",
  "baseServings": 2,
  "description": "唔使油炸，易潔鑊直接燜煮，酸辣開胃超下飯。",
  "difficulty": 2,
  "prepTime": 25,
  "imageUrl": "https://www.themealdb.com/images/media/meals/y7h0lq1683208993.jpg",
  "ingredients": [
    {
      "id": "cn9-1",
      "name": "茄子",
      "amount": "2條"
    },
    {
      "id": "cn9-2",
      "name": "免治豬肉",
      "amount": "100g"
    },
    {
      "id": "cn9-3",
      "name": "豆瓣醬",
      "amount": "1湯匙"
    },
    {
      "id": "cn9-4",
      "name": "醋",
      "amount": "1湯匙"
    },
    {
      "id": "cn9-5",
      "name": "糖",
      "amount": "1湯匙"
    }
  ],
  "steps": [
    "茄子切條，用鹽輕醃10分鐘出水，沖水洗去鹽分抹乾。",
    "易潔鑊中火下油，煎茄子至軟身微金邊，盛起。",
    "炒豬肉碎至變色，加豆瓣醬炒出紅油。",
    "倒茄子落去，加醋、糖同約80ml水。",
    "蓋蓋中火燜5分鐘至入味。",
    "開大火收汁，可加蔥花，酸辣平衡即可起鑊。"
  ]
}
