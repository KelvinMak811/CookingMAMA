{
  "id": "w-2",
  "name": "蘑菇奶油意粉",
  "cuisine": "western",
  "baseServings": 2,
  "description": "一個易潔鑊煮意粉同醬汁，奶油香濃，超易整。",
  "difficulty": 1,
  "prepTime": 20,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/f/f3/Tagliatelle_ai_funghi.jpg/960px-Tagliatelle_ai_funghi.jpg",
  "ingredients": [
    {
      "id": "w2-1",
      "name": "意粉",
      "amount": "200g"
    },
    {
      "id": "w2-2",
      "name": "蘑菇",
      "amount": "200g"
    },
    {
      "id": "w2-3",
      "name": "淡奶油",
      "amount": "150ml"
    },
    {
      "id": "w2-4",
      "name": "蒜蓉",
      "amount": "2瓣"
    },
    {
      "id": "w2-5",
      "name": "帕瑪森芝士",
      "amount": "30g"
    }
  ],
  "steps": [
    "蘑菇洗淨切片（每片約半厘米厚）；蒜瓣切細末；帕瑪森芝士刨成碎備用。",
    "大煲滾水加少許鹽，下意粉按包裝指示煮約8至10分鐘至彈牙，瀝乾留半杯麵水。",
    "易潔鑊中火落少許油，爆香蒜蓉約30秒至出香、未變焦。",
    "下蘑菇片中火炒3至4分鐘，炒至出水再收乾、邊緣略轉金黃。",
    "倒入淡奶油，轉中小火煮滾約2分鐘，醬汁變稠、能掛勺即可。",
    "拌入意粉同少許麵水兜勻，撒芝士碎，翻拌至芝士溶化、每條麵都裹上奶油醬即可起鑊。"
  ]
}
