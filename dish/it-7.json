{
  "id": "it-7",
  "name": "意式杂菜烩",
  "cuisine": "italian",
  "baseServings": 3,
  "description": "蔬菜烩意式风味，易洁锅焖煮，健康低脂。",
  "difficulty": 1,
  "prepTime": 30,
  "imageUrl": "https://www.themealdb.com/images/media/meals/wrpwuu1511786491.jpg",
  "ingredients": [
    {
      "id": "it7-1",
      "name": "翠玉瓜",
      "amount": "1条"
    },
    {
      "id": "it7-2",
      "name": "番茄",
      "amount": "3个"
    },
    {
      "id": "it7-3",
      "name": "茄子",
      "amount": "1条"
    },
    {
      "id": "it7-4",
      "name": "蒜蓉",
      "amount": "3瓣"
    },
    {
      "id": "it7-5",
      "name": "橄榄油",
      "amount": "3汤匙"
    }
  ],
  "steps": [
    "翠玉瓜、茄子切約3厘米滾刀塊；番茄切塊；蒜切細末。",
    "易潔鑊中火加橄欖油，爆香蒜蓉約30秒至出香。",
    "下茄子塊炒3至4分鐘至表面略軟、開始變色。",
    "加入翠玉瓜同番茄塊，翻炒2分鐘令蔬菜均勻裹油。",
    "蓋蓋轉中小火燜煮約12至15分鐘，間中翻拌，至全部蔬菜軟身、出汁融合。",
    "試味加鹽同黑胡椒，汁略收濃即可起鑊，冷食熱食都得。"
  ]
}
