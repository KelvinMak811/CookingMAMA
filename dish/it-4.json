{
  "id": "it-4",
  "name": "意式番茄炖鸡",
  "cuisine": "italian",
  "baseServings": 3,
  "description": "一锅炖鸡配番茄，易洁锅焖煮，适合一次煮多餐。",
  "difficulty": 2,
  "prepTime": 40,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/5/55/Chicken_cacciatore.jpg/960px-Chicken_cacciatore.jpg",
  "ingredients": [
    {
      "id": "it4-1",
      "name": "鸡腿肉",
      "amount": "500g"
    },
    {
      "id": "it4-2",
      "name": "番茄罐头",
      "amount": "1罐"
    },
    {
      "id": "it4-3",
      "name": "洋葱",
      "amount": "1个"
    },
    {
      "id": "it4-4",
      "name": "蒜蓉",
      "amount": "3瓣"
    },
    {
      "id": "it4-5",
      "name": "橄榄油",
      "amount": "2汤匙"
    }
  ],
  "steps": [
    "雞腿肉切約4厘米塊，用廚房紙印乾；洋蔥切丁；蒜切細末。",
    "易潔鑊中火加橄欖油，下雞塊煎至四面金黃，約每面2至3分鐘，盛起。",
    "同一鑊下洋蔥丁，中火炒3至4分鐘至軟身、略轉金黃。",
    "加入蒜蓉炒香30秒，倒回雞塊，加入番茄罐頭連汁拌勻。",
    "蓋蓋轉中小火燜煮約25分鐘，期間間中攪拌，至雞肉熟透、醬汁收濃。",
    "試味加鹽同黑胡椒，配意粉或麵包蘸汁食。"
  ]
}
