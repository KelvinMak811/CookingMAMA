{
  "id": "j-1",
  "name": "親子丼",
  "cuisine": "japanese",
  "baseServings": 2,
  "description": "日式滑蛋鸡肉饭，一个易洁锅搞定，超下饭。",
  "difficulty": 1,
  "prepTime": 20,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/0/0c/Oyakodon_Kyo_no_Tsukuneya.jpg",
  "ingredients": [
    {
      "id": "j1-1",
      "name": "鸡腿肉",
      "amount": "300g"
    },
    {
      "id": "j1-2",
      "name": "鸡蛋",
      "amount": "3只"
    },
    {
      "id": "j1-3",
      "name": "白饭",
      "amount": "2碗"
    },
    {
      "id": "j1-4",
      "name": "日式酱油",
      "amount": "3汤匙"
    },
    {
      "id": "j1-5",
      "name": "味醂",
      "amount": "2汤匙"
    }
  ],
  "steps": [
    "雞腿肉去皮切約2厘米闊條；3隻蛋打入碗輕打幾下，保留少許蛋白分明。",
    "日式醬油、味醂加100ml水調成煮汁，備用。",
    "易潔鑊中火倒入煮汁煮滾，下雞肉條鋪開，蓋蓋煮約5至6分鐘至雞肉全白、熟透。",
    "均勻淋入蛋液，蓋蓋轉中小火燜約1至2分鐘，見蛋邊凝固、中心仍略流心即關火。",
    "白飯盛碗，將雞蛋連汁蓋在飯面。",
    "可撒少許七味粉或蔥花，趁熱拌飯食。"
  ]
}
