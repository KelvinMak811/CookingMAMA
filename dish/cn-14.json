{
  "id": "cn-14",
  "name": "豉椒豬頸肉",
  "cuisine": "chinese",
  "baseServings": 2,
  "description": "港式小炒，豆豉椒絲配豬頸肉，鑊氣十足又惹味，送白飯最啱。",
  "difficulty": 2,
  "prepTime": 25,
  "imageUrl": "https://www.themealdb.com/images/media/meals/1529442316.jpg",
  "ingredients": [
    {
      "id": "cn14-1",
      "name": "豬頸肉",
      "amount": "350g"
    },
    {
      "id": "cn14-2",
      "name": "青紅椒",
      "amount": "各1個"
    },
    {
      "id": "cn14-3",
      "name": "豆豉",
      "amount": "1湯匙"
    },
    {
      "id": "cn14-4",
      "name": "蒜蓉",
      "amount": "3瓣"
    },
    {
      "id": "cn14-5",
      "name": "生抽",
      "amount": "1湯匙"
    },
    {
      "id": "cn14-6",
      "name": "生粉",
      "amount": "1茶匙"
    }
  ],
  "steps": [
    "豬頸肉切條，生抽、少許糖、生粉抓勻醃15分鐘。",
    "青紅椒去籽切絲；豆豉洗淨搗爛，蒜切蓉。",
    "易潔鑊大火燒熱下油，下豬頸肉快速炒至變色八成熟，盛起。",
    "鑊留底油，爆香豆豉蒜蓉至出香，下椒絲炒約1分鐘。",
    "倒回豬頸肉，大火兜炒均勻，試味調整鹹度。",
    "炒至汁濃貼肉即可起鑊，熱食最佳。"
  ]
}
