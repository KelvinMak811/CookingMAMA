{
  "id": "cn-7",
  "name": "揚州炒飯",
  "cuisine": "chinese",
  "baseServings": 2,
  "description": "隔夜飯炒出嚟最好食，一個易潔鑊搞掂午餐。",
  "difficulty": 1,
  "prepTime": 15,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/4/44/Special_Fried_Rice_-_Dumplings_Plus_AUD7_%283522091044%29.jpg/960px-Special_Fried_Rice_-_Dumplings_Plus_AUD7_%283522091044%29.jpg",
  "ingredients": [
    {
      "id": "cn7-1",
      "name": "隔夜白飯",
      "amount": "2碗"
    },
    {
      "id": "cn7-2",
      "name": "雞蛋",
      "amount": "2隻"
    },
    {
      "id": "cn7-3",
      "name": "火腿粒",
      "amount": "50g"
    },
    {
      "id": "cn7-4",
      "name": "青豆",
      "amount": "50g"
    },
    {
      "id": "cn7-5",
      "name": "生抽",
      "amount": "1湯匙"
    }
  ],
  "steps": [
    "隔夜飯用手指搓散；火腿切粒；青豆沖水洗淨。",
    "雞蛋打散，易潔鑊中火炒成滑蛋碎，盛起。",
    "大火下油，下飯快速炒散至粒粒分明。",
    "加火腿粒同青豆炒約1分鐘。",
    "倒返炒蛋，淋生抽兜匀。",
    "試味，可加少許胡椒粉，熱食最佳。"
  ]
}
