{
  "id": "j-8",
  "name": "豆腐汉堡排",
  "cuisine": "japanese",
  "baseServings": 2,
  "description": "日式豆腐肉饼，易洁锅煎香，健康又易做。",
  "difficulty": 2,
  "prepTime": 25,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/4/4e/Hamburg_steak.jpg",
  "ingredients": [
    {
      "id": "j8-1",
      "name": "免治猪肉",
      "amount": "200g"
    },
    {
      "id": "j8-2",
      "name": "嫩豆腐",
      "amount": "半盒"
    },
    {
      "id": "j8-3",
      "name": "洋葱",
      "amount": "半个"
    },
    {
      "id": "j8-4",
      "name": "鸡蛋",
      "amount": "1只"
    },
    {
      "id": "j8-5",
      "name": "面包糠",
      "amount": "3汤匙"
    }
  ],
  "steps": [
    "嫩豆腐用廚房紙或布巾包起壓去多餘水分；半個洋蔥切細末。",
    "免治豬肉、壓乾豆腐、洋蔥末、1隻蛋、面包糠加少許鹽同黑胡椒，用手拌至黏手、有黏性。",
    "分成4份，在掌心摔打幾下排氣，捏成約1厘米厚、8厘米闊嘅肉餅。",
    "易潔鑊中火加少許油，下肉餅煎約3至4分鐘，見底面金黃定型再翻面。",
    "另一面再煎3至4分鐘至全熟、兩面金黃酥脆。",
    "可選：加日式醬油、味醂各1湯匙煮1分鐘做照燒汁淋面。"
  ]
}
