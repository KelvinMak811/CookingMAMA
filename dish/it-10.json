{
  "id": "it-10",
  "name": "简易蘑菇烩饭",
  "cuisine": "italian",
  "baseServings": 2,
  "description": "Risotto 简化版，易洁锅不停搅拌，绵滑可口。",
  "difficulty": 2,
  "prepTime": 30,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/7/7c/Risotto.jpg/960px-Risotto.jpg",
  "ingredients": [
    {
      "id": "it10-1",
      "name": "意大利米",
      "amount": "200g"
    },
    {
      "id": "it10-2",
      "name": "蘑菇",
      "amount": "200g"
    },
    {
      "id": "it10-3",
      "name": "鸡汤",
      "amount": "600ml"
    },
    {
      "id": "it10-4",
      "name": "洋葱",
      "amount": "半个"
    },
    {
      "id": "it10-5",
      "name": "帕玛森芝士",
      "amount": "40g"
    }
  ],
  "steps": [
    "蘑菇切片；半個洋蔥切細丁；雞湯倒入小煲中火保溫；帕瑪森芝士刨碎。",
    "易潔鑊中火加少許油，炒洋蔥丁約2至3分鐘至軟身、透明。",
    "下蘑菇片炒3至4分鐘至出水收乾、邊緣微金黃，加入意大利米翻炒2分鐘至米粒略透明。",
    "分次加入雞湯，每次約80至100ml，邊加邊攪拌，待米吸收後再加，中火煮約16至18分鐘。",
    "見米飯變奶油狀、仍有少許咬勁（al dente）即關火。",
    "拌入芝士碎同少許牛油（可選），攪拌至絲滑即可起鑊。"
  ]
}
