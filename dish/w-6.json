{
  "id": "w-6",
  "name": "芝士火腿蛋卷",
  "cuisine": "western",
  "baseServings": 1,
  "description": "Omelette 快手午餐，易潔鑊幾分鐘搞掂。",
  "difficulty": 1,
  "prepTime": 10,
  "imageUrl": "https://www.themealdb.com/images/media/meals/hqaejl1695738653.jpg",
  "ingredients": [
    {
      "id": "w6-1",
      "name": "雞蛋",
      "amount": "3隻"
    },
    {
      "id": "w6-2",
      "name": "火腿片",
      "amount": "2片"
    },
    {
      "id": "w6-3",
      "name": "芝士片",
      "amount": "2片"
    },
    {
      "id": "w6-4",
      "name": "牛油",
      "amount": "15g"
    },
    {
      "id": "w6-5",
      "name": "鹽",
      "amount": "少許"
    }
  ],
  "steps": [
    "雞蛋打入碗內加少許鹽，攪打約30秒至均勻；火腿片切細條，芝士片對半切開。",
    "易潔鑊開中小火，落牛油待完全溶化、鍋面均勻覆上油膜。",
    "倒入蛋液，輕輕搖動鑊令蛋漿平均鋪開，煎約1至2分鐘至底部凝固、表面仍濕。",
    "在半熟蛋面鋪上火腿條同芝士片，用膠刮將蛋卷對折合起成半月形。",
    "再煎約1分鐘，兩面金黃、芝士溶化即可起鑊切件。"
  ]
}
