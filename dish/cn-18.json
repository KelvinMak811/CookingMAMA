{
  "id": "cn-18",
  "name": "干炒牛河",
  "cuisine": "chinese",
  "baseServings": 2,
  "description": "茶餐廳招牌干炒牛河，鑊氣夠、河粉不碎、牛肉嫩滑。",
  "difficulty": 3,
  "prepTime": 25,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/e/e3/Gon_caau_ngau_ho_%2820150222171214%29.JPG/960px-Gon_caau_ngau_ho_%2820150222171214%29.JPG",
  "ingredients": [
    {
      "id": "cn18-1",
      "name": "河粉",
      "amount": "400g"
    },
    {
      "id": "cn18-2",
      "name": "牛肉",
      "amount": "200g"
    },
    {
      "id": "cn18-3",
      "name": "芽菜",
      "amount": "100g"
    },
    {
      "id": "cn18-4",
      "name": "蔥",
      "amount": "2條"
    },
    {
      "id": "cn18-5",
      "name": "生抽",
      "amount": "2湯匙"
    },
    {
      "id": "cn18-6",
      "name": "老抽",
      "amount": "1茶匙"
    }
  ],
  "steps": [
    "牛肉切薄片，生抽、油、生粉醃15分鐘；河粉輕輕分開。",
    "蔥切段，芽菜洗淨瀝乾。",
    "易潔鑊大火燒到夠熱，下油炒牛肉至八成熟盛起。",
    "再加少許油，下河粉輕輕推炒，加生抽老抽上色。",
    "下芽菜同牛肉，大火快速兜炒，河粉微焦邊最香。",
    "撒蔥段再炒幾下即起鑊，要熱食。"
  ]
}
