{
  "id": "cn-17",
  "name": "蠔油炆水菜",
  "cuisine": "chinese",
  "baseServings": 2,
  "description": "經典港式蔬菜，水菜（通菜）炆到軟身入味，蒜香蠔油汁超下飯。",
  "difficulty": 1,
  "prepTime": 15,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/1/19/Pak_boong_fai_daeng.jpg/960px-Pak_boong_fai_daeng.jpg",
  "ingredients": [
    {
      "id": "cn17-1",
      "name": "水菜/通菜",
      "amount": "400g"
    },
    {
      "id": "cn17-2",
      "name": "蠔油",
      "amount": "2湯匙"
    },
    {
      "id": "cn17-3",
      "name": "蒜蓉",
      "amount": "4瓣"
    },
    {
      "id": "cn17-4",
      "name": "薑片",
      "amount": "3片"
    },
    {
      "id": "cn17-5",
      "name": "糖",
      "amount": "半茶匙"
    }
  ],
  "steps": [
    "水菜洗淨，摘段；粗梗同嫩葉分開放（梗先煮）。",
    "蠔油、糖同3湯匙水調成芡汁。",
    "易潔鑊中火下油，爆香薑片同蒜蓉至金黃。",
    "先下菜梗炒約1分鐘，再加菜葉炒軟。",
    "倒入芡汁，蓋蓋中火炆約2–3分鐘至菜軟身入味。",
    "試味，汁濃稠即可起鑊。"
  ]
}
