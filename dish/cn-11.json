{
  "id": "cn-11",
  "name": "港式咖喱牛腩",
  "cuisine": "chinese",
  "baseServings": 3,
  "description": "一次煮幾多餐超適合，易潔鑊燜到腍滑，隔餐仲好味。",
  "difficulty": 2,
  "prepTime": 50,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/2/29/Red_Curry_Beef_Brisket_in_Hong_Kong_Cha_Chaan_Teng.JPG/960px-Red_Curry_Beef_Brisket_in_Hong_Kong_Cha_Chaan_Teng.JPG",
  "ingredients": [
    {
      "id": "cn11-1",
      "name": "牛腩",
      "amount": "500g"
    },
    {
      "id": "cn11-2",
      "name": "咖喱磚",
      "amount": "2塊"
    },
    {
      "id": "cn11-3",
      "name": "薯仔",
      "amount": "2個"
    },
    {
      "id": "cn11-4",
      "name": "洋蔥",
      "amount": "1個"
    },
    {
      "id": "cn11-5",
      "name": "椰漿",
      "amount": "100ml"
    }
  ],
  "steps": [
    "牛腩切大件，冷水下鑊焯水去血沫，撈起洗淨。",
    "薯仔去皮切塊；洋蔥切角。",
    "易潔鑊中火炒洋蔥至透明，加咖喱磚同約400ml水煮溶。",
    "下牛腩同薯仔，大火煮滾後轉小火蓋蓋燜40–50分鐘。",
    "期間翻拌一至兩次，防止黏底。",
    "牛腩腍滑後加椰漿兜匀，試味，配白飯或多士。"
  ]
}
