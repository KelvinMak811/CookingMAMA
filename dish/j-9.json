{
  "id": "j-9",
  "name": "鲭鱼味噌煮",
  "cuisine": "japanese",
  "baseServings": 2,
  "description": "日式家常煮鱼，易洁锅焖煮，营养丰富。",
  "difficulty": 2,
  "prepTime": 25,
  "imageUrl": "https://www.themealdb.com/images/media/meals/diuub11782687570.jpg",
  "ingredients": [
    {
      "id": "j9-1",
      "name": "鲭鱼",
      "amount": "2片"
    },
    {
      "id": "j9-2",
      "name": "味噌",
      "amount": "2汤匙"
    },
    {
      "id": "j9-3",
      "name": "味醂",
      "amount": "2汤匙"
    },
    {
      "id": "j9-4",
      "name": "生姜",
      "amount": "3片"
    },
    {
      "id": "j9-5",
      "name": "水",
      "amount": "200ml"
    }
  ],
  "steps": [
    "鯖魚片沖水洗淨，用廚房紙印乾；每片橫切兩刀至魚骨（方便入味）；生薑切3片。",
    "味噌用少許水調開，再加味醂同剩餘水拌成煮汁。",
    "易潔鑊放入姜片，皮面朝下鋪上鯖魚，倒入煮汁，蓋蓋中火煮滾。",
    "轉中小火燜煮約8至10分鐘，期間用湯勺將汁淋在魚身上。",
    "揭蓋轉中大火收汁約2至3分鐘，見汁變稠、魚皮油亮即可。",
    "小心起魚，淋汁上碟，配白飯同食。"
  ]
}
