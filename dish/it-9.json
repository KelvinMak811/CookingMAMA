{
  "id": "it-9",
  "name": "香辣意式香肠炒意粉",
  "cuisine": "italian",
  "baseServings": 2,
  "description": "意式香肠配辣椒，易洁锅炒出浓香。",
  "difficulty": 2,
  "prepTime": 20,
  "imageUrl": "https://www.themealdb.com/images/media/meals/ustsqw1468250014.jpg",
  "ingredients": [
    {
      "id": "it9-1",
      "name": "意粉",
      "amount": "200g"
    },
    {
      "id": "it9-2",
      "name": "意式香肠",
      "amount": "2条"
    },
    {
      "id": "it9-3",
      "name": "番茄",
      "amount": "2个"
    },
    {
      "id": "it9-4",
      "name": "辣椒",
      "amount": "1只"
    },
    {
      "id": "it9-5",
      "name": "蒜蓉",
      "amount": "2瓣"
    }
  ],
  "steps": [
    "意式香腸斜刀切約半厘米厚片；番茄切丁；辣椒切圈；蒜切細末。",
    "意粉按包裝時間煮好瀝乾，留半杯麵水。",
    "易潔鑊中火下香腸片，煎至兩面金黃、出油，約3至4分鐘。",
    "加入蒜蓉同辣椒圈炒30秒至出香，下番茄丁煮約4至5分鐘至出汁略稠。",
    "拌入意粉同少許麵水，大火兜炒1至2分鐘，令每條麵裹上醬汁。",
    "試味加鹽（香腸本身夠鹹可省略），趁熱起鑊。"
  ]
}
