{
  "id": "j-4",
  "name": "日式咖喱饭",
  "cuisine": "japanese",
  "baseServings": 3,
  "description": "日式咖喱块焖煮，易洁锅一次煮多餐，隔餐更入味。",
  "difficulty": 1,
  "prepTime": 40,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/3/3c/Japanese_curry_rice.jpg/960px-Japanese_curry_rice.jpg",
  "ingredients": [
    {
      "id": "j4-1",
      "name": "鸡肉",
      "amount": "400g"
    },
    {
      "id": "j4-2",
      "name": "日式咖喱块",
      "amount": "1盒"
    },
    {
      "id": "j4-3",
      "name": "薯仔",
      "amount": "2个"
    },
    {
      "id": "j4-4",
      "name": "甘笋",
      "amount": "1条"
    },
    {
      "id": "j4-5",
      "name": "白饭",
      "amount": "3碗"
    }
  ],
  "steps": [
    "雞肉切約3厘米塊；薯仔、甘筍去皮切滾刀塊（每塊約3厘米），浸水備用。",
    "易潔鑊中火加少許油，下雞肉塊煎至表面金黃，約每面2至3分鐘。",
    "加入薯仔、甘筍塊翻炒1分鐘，倒入600ml水，蓋蓋大火煮滾。",
    "轉中小火燜煮約15分鐘，至薯仔筷子可插入、雞肉熟透。",
    "關火，將日式咖喱塊逐塊放入，攪拌至完全溶化，再開小火煮5分鐘至咖喱變稠。",
    "試味調整濃度，白飯盛碗，浇上咖喱即可。"
  ]
}
