{
  "id": "recipe-2",
  "name": "豉油皇炒麵",
  "cuisine": "chinese",
  "baseServings": 2,
  "description": "港式鑊氣炒麵，豉油香濃。一個易潔鑊就搞掂，午餐超方便。",
  "difficulty": 2,
  "prepTime": 20,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/a/a4/Chow_mein.jpg/960px-Chow_mein.jpg",
  "ingredients": [
    {
      "id": "i2-1",
      "name": "公仔麵/伊麵",
      "amount": "2個"
    },
    {
      "id": "i2-2",
      "name": "芽菜",
      "amount": "100g"
    },
    {
      "id": "i2-3",
      "name": "蔥",
      "amount": "2條"
    },
    {
      "id": "i2-4",
      "name": "生抽",
      "amount": "2湯匙"
    },
    {
      "id": "i2-5",
      "name": "老抽",
      "amount": "1茶匙"
    },
    {
      "id": "i2-6",
      "name": "糖",
      "amount": "半茶匙"
    }
  ],
  "steps": [
    "麵條用滾水焯軟（約2分鐘），即過冷河沖涼，徹底瀝乾水分。",
    "芽菜洗淨；蔥切段，葱白同葱葉分開。",
    "生抽、老抽、糖混勻成炒麵汁。",
    "易潔鑊大火燒熱下油，爆香葱白至微黃。",
    "下麵條快速推炒，淋炒麵汁兜匀上色。",
    "加芽菜同葱葉再炒約1分鐘，麵條乾身有鑊氣即可起鑊。"
  ]
}
