{
  "id": "w-8",
  "name": "奶油蘑菇雞扒",
  "cuisine": "western",
  "baseServings": 2,
  "description": "煎雞扒配奶油蘑菇醬，一個易潔鑊完成。",
  "difficulty": 2,
  "prepTime": 30,
  "imageUrl": "https://www.themealdb.com/images/media/meals/syqypv1486981727.jpg",
  "ingredients": [
    {
      "id": "w8-1",
      "name": "雞胸肉",
      "amount": "2塊"
    },
    {
      "id": "w8-2",
      "name": "蘑菇",
      "amount": "200g"
    },
    {
      "id": "w8-3",
      "name": "淡奶油",
      "amount": "120ml"
    },
    {
      "id": "w8-4",
      "name": "洋蔥",
      "amount": "半個"
    },
    {
      "id": "w8-5",
      "name": "鹽",
      "amount": "少許"
    }
  ],
  "steps": [
    "雞胸肉橫切開兩塊（變薄易熟），用刀背拍鬆，兩面撒鹽同黑胡椒醃10分鐘。",
    "蘑菇切片；半個洋蔥切細絲備用。",
    "易潔鑊中火加少許油，下雞胸煎至兩面金黃，每面約3至4分鐘，熟透盛起。",
    "同一鑊加少許油，中火炒洋蔥絲2分鐘至軟，下蘑菇片炒3至4分鐘至出水收乾。",
    "倒入淡奶油，轉中小火煮滾約2分鐘，醬汁變稠、顏色奶白。",
    "放回雞胸，蓋蓋燜2分鐘讓肉吸收醬汁，試味調鹽後起鑊。"
  ]
}
