{
  "id": "j-3",
  "name": "照烧鸡腿",
  "cuisine": "japanese",
  "baseServings": 2,
  "description": "甜甜照烧酱，易洁锅煎鸡腿，配饭一流。",
  "difficulty": 2,
  "prepTime": 25,
  "imageUrl": "https://www.themealdb.com/images/media/meals/wvpsxx1468256321.jpg",
  "ingredients": [
    {
      "id": "j3-1",
      "name": "鸡腿肉",
      "amount": "2块"
    },
    {
      "id": "j3-2",
      "name": "日式酱油",
      "amount": "3汤匙"
    },
    {
      "id": "j3-3",
      "name": "味醂",
      "amount": "3汤匙"
    },
    {
      "id": "j3-4",
      "name": "糖",
      "amount": "1汤匙"
    },
    {
      "id": "j3-5",
      "name": "姜蓉",
      "amount": "1茶匙"
    }
  ],
  "steps": [
    "雞腿肉去骨切開，皮面朝下用刀背拍鬆至約1厘米厚，用廚房紙印乾。",
    "日式醬油、味醂、糖、姜蓉加50ml水調成照燒汁，拌勻備用。",
    "易潔鑊中火少油，皮面朝下放入，煎約4至5分鐘至皮層金黃酥脆。",
    "翻面再煎3至4分鐘至雞肉熟透、兩面金黃。",
    "倒入照燒汁，轉中大火煮滾，不停用勺子將汁淋在雞肉上，約3至4分鐘至汁收稠、光亮掛面。",
    "取出切約2厘米闊段，排碟淋上剩餘照燒汁即可。"
  ]
}
