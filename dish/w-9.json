{
  "id": "w-9",
  "name": "經典牛柳粒",
  "cuisine": "western",
  "baseServings": 2,
  "description": "港式西餐茶餐廳款，易潔鑊快炒牛柳。",
  "difficulty": 2,
  "prepTime": 25,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/9/9d/Pepper_steak.jpg",
  "ingredients": [
    {
      "id": "w9-1",
      "name": "牛柳",
      "amount": "300g"
    },
    {
      "id": "w9-2",
      "name": "洋蔥",
      "amount": "半個"
    },
    {
      "id": "w9-3",
      "name": "生抽",
      "amount": "1湯匙"
    },
    {
      "id": "w9-4",
      "name": "蠔油",
      "amount": "1湯匙"
    },
    {
      "id": "w9-5",
      "name": "黑胡椒",
      "amount": "少許"
    }
  ],
  "steps": [
    "牛柳逆紋切粒（每粒約2厘米）；半個洋蔥切角塊；牛柳粒加生抽、蠔油、1茶匙生粉同少許油醃10分鐘。",
    "易潔鑊燒至冒煙，下油，大火下牛柳粒快速翻炒約1至2分鐘至七成熟、表面變色，盛起。",
    "鑊內補少許油，中火下洋蔥塊炒1至2分鐘至軟身、邊緣略金黃。",
    "倒回牛柳粒，大火兜炒30秒，撒黑胡椒。",
    "如太乾可加1至2湯匙水兜勻，汁略掛肉即可起鑊。",
    "趁熱食最嫩滑，唔好炒過火否則肉會韌。"
  ]
}
