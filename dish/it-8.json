{
  "id": "it-8",
  "name": "奶油培根意粉",
  "cuisine": "italian",
  "baseServings": 2,
  "description": "浓郁奶油培根面，易洁锅一锅完成。",
  "difficulty": 1,
  "prepTime": 20,
  "imageUrl": "https://www.themealdb.com/images/media/meals/0jv5gx1661040802.jpg",
  "ingredients": [
    {
      "id": "it8-1",
      "name": "意粉",
      "amount": "200g"
    },
    {
      "id": "it8-2",
      "name": "培根",
      "amount": "120g"
    },
    {
      "id": "it8-3",
      "name": "淡奶油",
      "amount": "150ml"
    },
    {
      "id": "it8-4",
      "name": "帕玛森芝士",
      "amount": "30g"
    },
    {
      "id": "it8-5",
      "name": "黑胡椒",
      "amount": "少许"
    }
  ],
  "steps": [
    "培根切約半厘米闊條；帕瑪森芝士刨碎備用。",
    "意粉煮至彈牙，瀝乾留半杯麵水。",
    "易潔鑊中火煎培根條約3至4分鐘至酥脆出油、邊緣金黃。",
    "倒入淡奶油，轉中小火煮滾約2分鐘，汁變稠、顏色奶白。",
    "拌入意粉同少許麵水兜勻，撒芝士碎翻拌至溶化。",
    "加黑胡椒試味，立即起鑊食，避免奶油醬放涼變稠。"
  ]
}
