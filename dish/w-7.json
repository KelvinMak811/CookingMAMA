{
  "id": "w-7",
  "name": "蒜香牛油蝦",
  "cuisine": "western",
  "baseServings": 2,
  "description": "西式蒜香蝦，易潔鑊大火快炒，鮮甜惹味。",
  "difficulty": 1,
  "prepTime": 15,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/1/12/Shrimp_scampi.jpg/960px-Shrimp_scampi.jpg",
  "ingredients": [
    {
      "id": "w7-1",
      "name": "大蝦",
      "amount": "300g"
    },
    {
      "id": "w7-2",
      "name": "牛油",
      "amount": "30g"
    },
    {
      "id": "w7-3",
      "name": "蒜蓉",
      "amount": "4瓣"
    },
    {
      "id": "w7-4",
      "name": "白酒",
      "amount": "2湯匙"
    },
    {
      "id": "w7-5",
      "name": "parsley",
      "amount": "適量"
    }
  ],
  "steps": [
    "大蝦去殼留尾，用牙籤挑走蝦腸，沖水洗淨後用廚房紙徹底印乾，否則煎時會爆油。",
    "蒜瓣切細末；parsley 切碎備用。",
    "易潔鑊中火落牛油，待溶化後下蒜蓉，炒香約30秒至金黃、未焦。",
    "轉大火下蝦，單面煎約1分鐘至變紅，翻面再煎1分鐘，蝦身彎曲、全紅即熟。",
    "沿鍋邊淋入白酒，讓酒精揮發約30秒，汁略收濃。",
    "撒香草碎，翻拌均勻即可起鑊，趁熱食。"
  ]
}
