{
  "id": "j-2",
  "name": "牛肉饭",
  "cuisine": "japanese",
  "baseServings": 2,
  "description": "吉野家风格牛肉饭，易洁锅快煮，备餐首选。",
  "difficulty": 1,
  "prepTime": 20,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/d/d2/Gy%C5%ABdon.jpg/960px-Gy%C5%ABdon.jpg",
  "ingredients": [
    {
      "id": "j2-1",
      "name": "肥牛片",
      "amount": "300g"
    },
    {
      "id": "j2-2",
      "name": "洋葱",
      "amount": "1个"
    },
    {
      "id": "j2-3",
      "name": "白饭",
      "amount": "2碗"
    },
    {
      "id": "j2-4",
      "name": "日式酱油",
      "amount": "3汤匙"
    },
    {
      "id": "j2-5",
      "name": "味醂",
      "amount": "2汤匙"
    }
  ],
  "steps": [
    "洋蔥切半厘米幼絲；肥牛片室溫解凍後輕輕分開，備用。",
    "日式醬油、味醂加150ml水調成煮汁。",
    "易潔鑊中火倒入煮汁煮滾，下洋蔥絲煮約3至4分鐘至軟身、半透明。",
    "下肥牛片鋪開，用筷子輕輕撥散，大火煮約1至2分鐘至肉變色、剛熟即可，唔好煮過火。",
    "試味，可按喜好加少許糖調甜。",
    "白飯盛碗，將牛肉連汁蓋在飯上，趁熱食。"
  ]
}
