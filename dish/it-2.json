{
  "id": "it-2",
  "name": "番茄罗勒意粉",
  "cuisine": "italian",
  "baseServings": 2,
  "description": "清新意式番茄面，易洁锅快煮，夏日首选。",
  "difficulty": 1,
  "prepTime": 20,
  "imageUrl": "https://www.themealdb.com/images/media/meals/vpcqn01763335688.jpg",
  "ingredients": [
    {
      "id": "it2-1",
      "name": "意粉",
      "amount": "200g"
    },
    {
      "id": "it2-2",
      "name": "新鲜番茄",
      "amount": "4个"
    },
    {
      "id": "it2-3",
      "name": "蒜蓉",
      "amount": "3瓣"
    },
    {
      "id": "it2-4",
      "name": "罗勒叶",
      "amount": "适量"
    },
    {
      "id": "it2-5",
      "name": "橄榄油",
      "amount": "3汤匙"
    }
  ],
  "steps": [
    "新鮮番茄底部劃十字，滾水燙30秒去皮，切約1厘米小丁；蒜切細末；羅勒葉洗淨備用。",
    "意粉按包裝時間煮至彈牙，瀝乾留半杯麵水。",
    "易潔鑊中火加橄欖油，爆香蒜蓉約30秒至金黃出香。",
    "下番茄丁，加少許鹽，中火煮約5至7分鐘至番茄出汁、略收稠成醬狀。",
    "拌入意粉同少許麵水，大火兜炒1至2分鐘至每條麵裹上番茄汁。",
    "關火後撒羅勒葉（保留香氣），翻拌均勻即可起鑊。"
  ]
}
