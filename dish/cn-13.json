{
  "id": "cn-13",
  "name": "香煎豬頸肉",
  "cuisine": "chinese",
  "baseServings": 2,
  "description": "豬頸肉脂肪均勻，煎到外脆內嫩超juicy。茶餐廳人氣款，配白飯或炒粉都一流，絕對唔係湯飯！",
  "difficulty": 2,
  "prepTime": 30,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/c/c2/Char_siu_pork.jpg/960px-Char_siu_pork.jpg",
  "ingredients": [
    {
      "id": "cn13-1",
      "name": "豬頸肉",
      "amount": "400g"
    },
    {
      "id": "cn13-2",
      "name": "生抽",
      "amount": "2湯匙"
    },
    {
      "id": "cn13-3",
      "name": "蜜糖",
      "amount": "1湯匙"
    },
    {
      "id": "cn13-4",
      "name": "蒜蓉",
      "amount": "3瓣"
    },
    {
      "id": "cn13-5",
      "name": "黑胡椒",
      "amount": "少許"
    }
  ],
  "steps": [
    "豬頸肉洗淨抹乾，逆紋切厚片（約1厘米），用刀背輕輕拍鬆。",
    "生抽、蜜糖、蒜蓉、黑胡椒混勻，醃豬頸肉至少20分鐘。",
    "易潔鑊中火燒熱，下1湯匙油，逐片下豬頸肉，唔好一次過放滿。",
    "每面煎約2–3分鐘至金黃微焦，內裡熟透即可，期間勿不停翻動。",
    "全部煎好後切細條或保持原片，淋上鑊裡剩餘醬汁收濃。",
    "即起鑊熱食，可配生菜包住食。"
  ]
}
