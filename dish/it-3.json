{
  "id": "it-3",
  "name": "培根蛋意粉",
  "cuisine": "italian",
  "baseServings": 2,
  "description": "Carbonara 简易版，易洁锅完成，浓郁蛋香。",
  "difficulty": 2,
  "prepTime": 20,
  "imageUrl": "https://www.themealdb.com/images/media/meals/llcbn01574260722.jpg",
  "ingredients": [
    {
      "id": "it3-1",
      "name": "意粉",
      "amount": "200g"
    },
    {
      "id": "it3-2",
      "name": "烟肉/培根",
      "amount": "150g"
    },
    {
      "id": "it3-3",
      "name": "鸡蛋",
      "amount": "2只"
    },
    {
      "id": "it3-4",
      "name": "帕玛森芝士",
      "amount": "50g"
    },
    {
      "id": "it3-5",
      "name": "黑胡椒",
      "amount": "少许"
    }
  ],
  "steps": [
    "煙肉切細條；2隻全蛋加帕瑪森芝士碎、大量黑胡椒拌成蛋芝士汁，備用。",
    "意粉煮至 al dente，瀝乾留1杯麵水。",
    "易潔鑊中火不下油（煙肉會出油），煎煙肉條約3至4分鐘至酥脆出油、邊緣金黃。",
    "關火，快速倒入意粉同煙肉兜勻，利用餘溫降低鑊溫（避免蛋變熟蛋碎）。",
    "離火倒入蛋芝士汁，快速攪拌約30秒，加麵水調至奶油狀掛面。",
    "即起鑊撒黑胡椒，蛋汁應呈絲滑奶黃色、唔好炒到結塊。"
  ]
}
