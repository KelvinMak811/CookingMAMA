{
  "id": "recipe-6",
  "name": "蒸水蛋",
  "cuisine": "chinese",
  "baseServings": 2,
  "description": "超簡單家常菜，易潔鑊加蒸架就得，滑嫩如豆腐花。",
  "difficulty": 1,
  "prepTime": 20,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/b/bb/Chinese_steamed_eggs_with_char_siu_by_yomi955.jpg",
  "ingredients": [
    {
      "id": "i6-1",
      "name": "雞蛋",
      "amount": "3隻"
    },
    {
      "id": "i6-2",
      "name": "溫水",
      "amount": "450ml"
    },
    {
      "id": "i6-3",
      "name": "生抽",
      "amount": "1湯匙"
    },
    {
      "id": "i6-4",
      "name": "蔥花",
      "amount": "適量"
    }
  ],
  "steps": [
    "雞蛋打入大碗，加少許鹽，順一方向打散。",
    "慢慢倒入溫水（蛋水比例約1:1.5），輕輕攪匀。",
    "用細篩過濾蛋液入蒸碟，撇走表面氣泡。",
    "蓋錫紙或保紙，戳幾個小孔防止水滴落。",
    "易潔鑊水滾後轉中火，蒸約12分鐘至凝固嫩滑。",
    "淋生抽撒蔥花，可加少許麻油。"
  ]
}
