{
  "id": "j-10",
  "name": "茶碗蒸",
  "cuisine": "japanese",
  "baseServings": 2,
  "description": "用易洁锅加蒸架蒸蛋羹，滑嫩鲜美。",
  "difficulty": 2,
  "prepTime": 25,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/6/6e/Chawanmushi_001.jpg/960px-Chawanmushi_001.jpg",
  "ingredients": [
    {
      "id": "j10-1",
      "name": "鸡蛋",
      "amount": "3只"
    },
    {
      "id": "j10-2",
      "name": "鸡汤",
      "amount": "300ml"
    },
    {
      "id": "j10-3",
      "name": "虾仁",
      "amount": "6只"
    },
    {
      "id": "j10-4",
      "name": "香菇",
      "amount": "2朵"
    },
    {
      "id": "j10-5",
      "name": "酱油",
      "amount": "少许"
    }
  ],
  "steps": [
    "蝦仁去腸洗淨；香菇切薄片；3隻蛋打入碗，加雞湯輕打均勻，用篩過濾1至2次去除氣泡。",
    "準備2個蒸碗，碗底放入蝦仁同香菇片，均勻倒入蛋液至八分滿。",
    "用錫紙或保鮮紙輕蓋碗面（避免水滴落令蛋面不平）。",
    "易潔鑊加蒸架，倒入約1厘米深水，大火煮滾後轉中火，放入蒸碗，蓋蓋蒸約12至15分鐘。",
    "用筷子插入中心，流出清澈汁液即熟透；如仍液體狀則多蒸2分鐘。",
    "取出淋少許醬油，趁熱食。"
  ]
}
