{
  "id": "w-5",
  "name": "北非蛋 Shakshuka",
  "cuisine": "western",
  "baseServings": 2,
  "description": "蕃茄蛋一鑊過，易潔鑊直接燜，配麵包超正。",
  "difficulty": 1,
  "prepTime": 20,
  "imageUrl": "https://www.themealdb.com/images/media/meals/g373701551450225.jpg",
  "ingredients": [
    {
      "id": "w5-1",
      "name": "雞蛋",
      "amount": "4隻"
    },
    {
      "id": "w5-2",
      "name": "番茄罐頭",
      "amount": "1罐"
    },
    {
      "id": "w5-3",
      "name": "紅椒",
      "amount": "1個"
    },
    {
      "id": "w5-4",
      "name": "洋蔥",
      "amount": "1個"
    },
    {
      "id": "w5-5",
      "name": "孜然粉",
      "amount": "1茶匙"
    }
  ],
  "steps": [
    "洋蔥、紅椒去籽切細丁（約半厘米）；番茄罐頭用匙壓碎備用。",
    "易潔鑊中火加2湯匙油，下洋蔥丁炒2至3分鐘至軟身、略轉透明。",
    "加入紅椒丁再炒2分鐘，炒至略軟出香。",
    "倒入番茄碎同孜然粉，拌勻後煮滾，轉中小火蓋蓋燜5分鐘，醬汁略收稠。",
    "用匙在醬汁上挖出4個小坑，逐隻打入雞蛋，蓋蓋燜3至5分鐘。",
    "見蛋白凝固、蛋黃仍略流心（或依喜好多燜1至2分鐘全熟），配烤多士或麵包蘸醬汁食。"
  ]
}
