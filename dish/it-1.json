{
  "id": "it-1",
  "name": "蒜香橄榄油意粉",
  "cuisine": "italian",
  "baseServings": 2,
  "description": "Aglio e Olio 经典，易洁锅煮面炒蒜，5样材料就搞定。",
  "difficulty": 1,
  "prepTime": 15,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/5/50/Spaghetti_aglio_e_olio.jpg/960px-Spaghetti_aglio_e_olio.jpg",
  "ingredients": [
    {
      "id": "it1-1",
      "name": "意粉",
      "amount": "200g"
    },
    {
      "id": "it1-2",
      "name": "蒜蓉",
      "amount": "6瓣"
    },
    {
      "id": "it1-3",
      "name": "橄榄油",
      "amount": "4汤匙"
    },
    {
      "id": "it1-4",
      "name": "辣椒碎",
      "amount": "少许"
    },
    {
      "id": "it1-5",
      "name": "parsley",
      "amount": "适量"
    }
  ],
  "steps": [
    "蒜瓣切薄片（約2毫米厚）；parsley 切碎備用。",
    "大煲滾水加鹽，下意粉煮約1分鐘少於包裝時間至 al dente，瀝乾留半杯麵水。",
    "易潔鑊小火加橄欖油，下蒜片同辣椒碎，慢慢煎約2至3分鐘至蒜片金黃、出香，唔好煎焦。",
    "轉中火倒入意粉同2至3湯匙麵水，用筷子快速拌炒約1分鐘，令油汁乳化裹面。",
    "試味加鹽，撒香草碎。",
    "立即起鑊，蒜香意粉要熱食先最香。"
  ]
}
