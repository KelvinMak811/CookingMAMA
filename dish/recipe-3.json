{
  "id": "recipe-3",
  "name": "清蒸鱸魚",
  "cuisine": "chinese",
  "baseServings": 2,
  "description": "保留魚肉鮮甜，用蒸架放喺易潔鑊上面蒸就得，唔使焗爐。",
  "difficulty": 2,
  "prepTime": 25,
  "imageUrl": "https://www.themealdb.com/images/media/meals/tqd7s21763780609.jpg",
  "ingredients": [
    {
      "id": "i3-1",
      "name": "鱸魚",
      "amount": "1條"
    },
    {
      "id": "i3-2",
      "name": "薑絲",
      "amount": "適量"
    },
    {
      "id": "i3-3",
      "name": "蔥絲",
      "amount": "適量"
    },
    {
      "id": "i3-4",
      "name": "蒸魚豉油",
      "amount": "3湯匙"
    },
    {
      "id": "i3-5",
      "name": "料酒",
      "amount": "1湯匙"
    }
  ],
  "steps": [
    "鱸魚去鱗內臟洗淨，魚身劃兩刀，用料酒同少許鹽內外抹勻醃10分鐘。",
    "魚肚放入部分薑絲，碟底鋪薑蔥，魚放上面。",
    "易潔鑊加足夠水燒滾，放蒸架，大火蒸8–10分鐘（視魚大小）。",
    "用筷子戳最厚部位，能輕鬆穿透即熟。",
    "倒掉蒸魚水（較腥），鋪上新鲜薑蔥絲。",
    "另起小鑊燒熱2湯匙油淋在魚上，再淋蒸魚豉油即可。"
  ]
}
