{
  "id": "it-5",
  "name": "蒜香虾仁意粉",
  "cuisine": "italian",
  "baseServings": 2,
  "description": "鲜虾意粉，易洁锅15分钟搞定，餐厅级美味。",
  "difficulty": 1,
  "prepTime": 15,
  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/1/1b/Spaghetti_with_shrimp.jpg/960px-Spaghetti_with_shrimp.jpg",
  "ingredients": [
    {
      "id": "it5-1",
      "name": "意粉",
      "amount": "200g"
    },
    {
      "id": "it5-2",
      "name": "大虾",
      "amount": "250g"
    },
    {
      "id": "it5-3",
      "name": "蒜蓉",
      "amount": "4瓣"
    },
    {
      "id": "it5-4",
      "name": "白酒",
      "amount": "2汤匙"
    },
    {
      "id": "it5-5",
      "name": "橄榄油",
      "amount": "3汤匙"
    }
  ],
  "steps": [
    "大蝦去殼留尾，挑走蝦腸，洗淨後徹底印乾；蒜切薄片。",
    "意粉按包裝時間煮至彈牙，瀝乾留半杯麵水。",
    "易潔鑊中火加橄欖油，下蒜片煎約1分鐘至金黃出香，注意唔好焦。",
    "轉大火下蝦，單面煎約1分鐘至變紅，翻面再煎1分鐘至全熟。",
    "沿鍋邊淋白酒，揮發約30秒至酒味散去、汁略收。",
    "拌入意粉同少許麵水兜勻，試味加鹽、黑胡椒即可起鑊。"
  ]
}
